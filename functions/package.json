{
  "name": "cuerate-functions",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "lib/index.js",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "build": "tsc",
    "circle:register-entity-secret": "node --env-file=.env scripts/register-entity-secret.mjs",
    "circle:entity-secret-ciphertext": "node --env-file=.env scripts/entity-secret-ciphertext.mjs",
    "circle:create-wallet-set": "node --env-file=.env scripts/create-wallet-set.mjs",
    "serve": "npm run build && firebase emulators:start --only functions",
    "deploy": "npm run build && firebase deploy --only functions",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@circle-fin/developer-controlled-wallets": "^8.0.0",
    "firebase-admin": "^13.0.0",
    "firebase-functions": "^6.0.1"
  },
  "devDependencies": {
    "typescript": "^6.0.2"
  }
}
