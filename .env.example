VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_USE_FIREBASE_EMULATORS=false

# Supabase Storage Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_SUPABASE_BUCKET=cuerate-media

# Firebase Functions / Circle server env vars
# Put these in functions/.env for local emulators or Firebase Secret Manager for deployed functions.
CIRCLE_API_KEY=TEST_API_KEY
CIRCLE_ENTITY_SECRET=32_byte_hex_entity_secret
CIRCLE_WALLET_SET_ID=wallet_set_id
CIRCLE_BLOCKCHAIN=ARC-TESTNET
CIRCLE_ACCOUNT_TYPE=SCA
CIRCLE_USDC_TOKEN_ADDRESS=
CUERATE_ALLOW_LIVE_TRANSFERS=false
