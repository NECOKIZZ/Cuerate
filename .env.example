VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_USE_FIREBASE_EMULATORS=false

# Supabase Storage Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_SUPABASE_BUCKET=cuerate-media

# Firebase Functions / Circle server env vars
# Put these in functions/.env for local emulators or Firebase Secret Manager for deployed functions.
CIRCLE_API_KEY=TEST_API_KEY
CIRCLE_ENTITY_SECRET=32_byte_hex_entity_secret
CIRCLE_WALLET_SET_ID=wallet_set_id
CIRCLE_BLOCKCHAIN=ARC-TESTNET
CIRCLE_ACCOUNT_TYPE=SCA
CIRCLE_USDC_TOKEN_ADDRESS=
CUERATE_ALLOW_LIVE_TRANSFERS=false

# Inspiration API ("Pinterest for Agents")
# Price charged per /inspire query (USDC decimal string).
INSPIRE_PRICE_USDC=0.05
# Platform treasury wallet that receives the 10% cut (and any folded shares).
# Provide an address directly, or a Cuerate uid whose wallet to resolve.
PLATFORM_CIRCLE_WALLET_ADDRESS=
PLATFORM_CIRCLE_WALLET_UID=
# Agent key -> Cuerate uid map for the demo client: "key1:uid1,key2:uid2".
# (Production keys can instead live in the admin-only `agentKeys/{key}` Firestore collection.)
INSPIRE_AGENT_KEYS=

# --- Stage 2: fully on-chain royalties (Arc smart contract) ---
# Set to "true" to route /inspire settlement through the CuerateRoyalty contract instead of
# the off-chain Circle transfer loop. Leave unset for the off-chain fallback.
INSPIRE_ONCHAIN=false
# Deployed CuerateRoyalty contract address on Arc testnet.
ROYALTY_CONTRACT_ADDRESS=
# Arc testnet ERC-20 USDC (6 decimals). Defaults to the canonical Arc address if blank.
ARC_USDC_ADDRESS=0x3600000000000000000000000000000000000000
# Circle dev-controlled wallet that owns the contract + receives the platform cut (treasury)
# and registers forks on-chain. Created by `npm run circle:create-platform-wallet`.
REGISTRAR_WALLET_ID=
REGISTRAR_WALLET_ADDRESS=

# Demo agent (the external buyer that pays /inspire). Created by `npm run circle:create-agent-wallet`.
# /inspire charges this wallet directly when the request's x-agent-key matches INSPIRE_AGENT_KEY.
INSPIRE_AGENT_KEY=demokey
INSPIRE_AGENT_WALLET_ID=
INSPIRE_AGENT_WALLET_ADDRESS=
